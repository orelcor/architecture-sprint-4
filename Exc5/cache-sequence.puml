@startuml Cache sequence Александрит
actor Пользователь
participant "Приложение MES" as MES
participant "Кеш" as Cache
participant "База данных" as DB

Пользователь -> MES: Запросить список заказов
MES -> Cache: Проверить наличие данных
alt Данные найдены
    Cache -> MES: Данные
    MES -> Пользователь: Вернуть список заказов
else Данные не найдены
    Cache -> MES: Нет данных
    MES -> DB: Запросить список заказов
    DB -> MES: Вернуть список заказов
    MES -> Cache: Сохранить данные с TTL
    MES -> Пользователь: Вернуть список заказов
end

Пользователь -> MES: Изменить статус заказа
MES -> DB: Обновить статус заказа
DB -> MES: Подтверждение изменения
MES -> Cache: Удалить данные о статусе заказа

@enduml